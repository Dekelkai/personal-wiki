{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/frontmatter.schema.json",
  "title": "个人知识库 Frontmatter",
  "type": "object",
  "required": ["title", "type", "domain", "status", "publish", "created", "updated"],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "type": {
      "type": "string",
      "enum": ["index", "concept", "topic", "method", "dataset", "metric", "paper", "survey", "experiment", "project", "decision", "guide", "troubleshooting", "reference", "article"]
    },
    "domain": {
      "type": "string",
      "enum": ["home", "research", "engineering", "ai", "projects", "writing", "reference"]
    },
    "status": {"type": "string", "enum": ["draft", "maintained", "completed", "archived"]},
    "publish": {"type": "boolean"},
    "created": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "updated": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "authors": {"type": "array", "items": {"type": "string"}},
    "venue": {"type": "string"},
    "year": {"type": "integer"},
    "doi": {"type": "string"},
    "url": {"type": "string"},
    "license": {"type": "string"},
    "version": {"type": "string"},
    "project_status": {"type": "string"},
    "tags": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
